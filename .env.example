APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Dev:  http://localhost:8000  (hoặc http://127.0.0.1:8000 — phải khớp với php artisan serve)
# Prod: https://yourdomain.com  (không có trailing slash, không có port cho 80/443)
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Cho phép php artisan serve xử lý nhiều request đồng thời (chỉ ảnh hưởng built-in PHP server)
# Production dùng nginx/php-fpm nên setting này không có tác dụng
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SANCTUM_STATEFUL_DOMAINS chỉ cần khi frontend và API khác domain.
# Khi cùng domain, Sanctum tự derive từ APP_URL — không cần set thủ công.

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Laravel Reverb (WebSocket) ──────────────────────────────────────────
# Generate keys: php artisan reverb:install
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Browser Push (Web Push API) ──────────────────────────────────────────
# Generate keys: php artisan webpush:vapid
VAPID_SUBJECT="mailto:admin@yourdomain.com"
VAPID_PUBLIC_KEY=
# NOTE: VAPID_PRIVATE_KEY must NOT be committed — generate per environment

# ── FPT.AI ID Recognition (eKYC CCCD OCR) ───────────────────────────────
# Lấy API key tại: https://console.fpt.ai → tạo ứng dụng → chọn "ID Recognition"
# Docs: https://docs.fpt.ai/vision/id-recognition
FPT_AI_API_KEY=
# FPT_AI_BASE_URL=https://api.fpt.ai/vision/idr/vnm
# FPT_AI_OCR_TIMEOUT=20
